    "inputs": [],
    "settable_properties": {
      "UTiling": {"type": "float", "description": "U方向平铺次数"},
      "VTiling": {"type": "float", "description": "V方向平铺次数"},
      "CoordinateIndex": {"type": "int", "description": "UV通道索引"}
    },
    "tags": ["uv", "coordinate", "tiling", "material"]
  },
  "MaterialExpressionTime": {
    "title": "Time (时间)",
    "description": "输出引擎时间（秒），用于动画效果",
