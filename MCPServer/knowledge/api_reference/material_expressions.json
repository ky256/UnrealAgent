  "MaterialExpressionTextureSample": {
    "title": "TextureSample (纹理采样)",
    "description": "采样一个纹理资源，输出颜色和各通道",
    "outputs": [
      {"name": "RGB", "type": "float3"},
      {"name": "R", "type": "float"},
      {"name": "G", "type": "float"},
      {"name": "B", "type": "float"},
      {"name": "A", "type": "float"}
    ],
    "inputs": [
      {"name": "UVs", "type": "float2", "optional": true}
    ],
    "settable_properties": {
      "texture_path": {
        "type": "string",
        "description": "纹理资产路径（通过 set_expression_value 专属处理）",
        "example": "/Game/Textures/T_Wood_BaseColor"
      }
    },
    "important_notes": [
      "使用 set_expression_value 时 property_name 为 'texture_path'",
      "value 为纹理资产的完整路径如 '/Game/Textures/T_Wood'"
    ],
    "tags": ["texture", "sample", "uv", "material"]
  },
  "MaterialExpressionTextureCoordinate": {
    "title": "TextureCoordinate (纹理坐标)",
    "description": "输出 UV 纹理坐标，可设置 Tiling 和 Offset",
